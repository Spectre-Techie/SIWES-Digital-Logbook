{
  "name": "siwes-digital-logbook",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "build": "pnpm --filter client build && pnpm --filter server build",
    "lint": "pnpm --filter client lint && pnpm --filter server lint",
    "test": "pnpm --filter server test && pnpm --filter client test",
    "test:server": "pnpm --filter server test",
    "test:client": "pnpm --filter client test"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}